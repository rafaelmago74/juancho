<style>
  .wpc-internal-ad {
    position: relative;
    z-index: 1035;
    width: 100vw !important;
    margin-left: calc(50% - 50vw) !important;
    border-radius: 0 !important;
    -webkit-border-radius: 0 !important;
    overflow: hidden !important;
  }
  .wpc-internal-ad::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: #000;
    z-index: -1;
    pointer-events: none;
  }
  /* Do NOT collapse on scroll. This banner is position:relative (in normal flow)
     and is ALREADY scrolled off-screen when .wpc-top-ad-hidden turns on, so the
     old display:none/height:0 collapse only reflowed the whole page UP ~56px —
     the dominant scroll CLS on regional pages (where the Ascend top-ad is absent
     and this internal banner fills the top slot). Reserve the space; just hide
     it visually (invisible + non-interactive) so nothing below moves. */
  body.wpc-top-ad-hidden .wpc-internal-ad {
    opacity: 0 !important;
    pointer-events: none !important;
  }
</style>
